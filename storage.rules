rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('admin', false) == true ||
        (request.auth.token.email == null
          ? false
          : request.auth.token.email.lower() == 'vinko.mitar@gmail.com')
      );
    }

    function isStaff() {
      return isSignedIn() && (
        isAdmin() ||
        request.auth.token.get('agent', false) == true ||
        request.auth.token.get('captain', false) == true ||
        request.auth.token.get('crew', false) == true
      );
    }

    function isAllowedUpload() {
      return request.resource.size < 15 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType == 'application/pdf'
        );
    }

    // Inquiry chat files — owner-scoped path
    match /inquiries/{ownerUid}/{inquiryId}/{fileName} {
      allow read:   if request.auth.uid == ownerUid || isStaff();
      allow create: if request.auth.uid == ownerUid && isAllowedUpload();
      allow update: if isAdmin();
      allow delete: if request.auth.uid == ownerUid || isAdmin();
    }

    // RECOMMENDED owner-scoped path (change chatUpload.ts, then uncomment):
    // match /inquiries/{ownerUid}/{inquiryId}/{fileName} {
    //   allow read:   if request.auth.uid == ownerUid || isStaff();
    //   allow create: if request.auth.uid == ownerUid && isAllowedUpload();
    //   allow update: if isAdmin();
    //   allow delete: if request.auth.uid == ownerUid || isAdmin();
    // }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
